          "mapping": "Verde principal de CTAs/headers"
        },
        "600": {
          "value": "#1d2748",
          "description": "Primary button fill, active states",
          "mapping": "Verde principal de CTAs/headers"
        },
        "500": {
          "value": "#22305a",
          "description": "Brand color variations, charts, active icons",
          "mapping": "Verde principal de CTAs/headers"
        },
        "400": {
          "value": "#2a3a6d",
          "description": "Secondary brand color for medium elements",
          "mapping": "Verde medio de botones secundarios/bordes"
        },
        "300": {
